# =============================================================================
# Mar Sem Lixo - .gitignore híbrido
# Cobre: Java/Maven, Node/JavaScript, IntelliJ, VS Code, Cursor, OS, AWS CDK
# =============================================================================

# -----------------------------------------------------------------------------
# Java (compiled classes, logs e arquivos diversos)
# -----------------------------------------------------------------------------
*.class
*.log
*.ctxt
.mtj.tmp/

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# JVM crash logs
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# Maven
# -----------------------------------------------------------------------------
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------------------------------------
# Gradle (caso seja adicionado no futuro)
# -----------------------------------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# -----------------------------------------------------------------------------
# Node / npm / pnpm / yarn
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# -----------------------------------------------------------------------------
# Frontend build outputs
# -----------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
.vite/
.cache/
.parcel-cache/
.next/
.nuxt/
.svelte-kit/
*.local

# TypeScript
*.tsbuildinfo
.tsbuildinfo

# -----------------------------------------------------------------------------
# Test e coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
junit.xml
test-results/
playwright-report/
.playwright/

# -----------------------------------------------------------------------------
# Variáveis de ambiente (NUNCA comitar!)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
*.pem
*.key

# Manter exemplos (estes SIM devem ser comitados)
!.env.example
!.env.sample

# -----------------------------------------------------------------------------
# IntelliJ IDEA / JetBrains
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
.idea_modules/
out/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties

# -----------------------------------------------------------------------------
# VS Code
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
*.code-workspace

# -----------------------------------------------------------------------------
# Cursor
# -----------------------------------------------------------------------------
.cursor/
# Manter regras compartilhadas do time, se houver
!.cursor/rules/
!.cursorignore

# -----------------------------------------------------------------------------
# Outros editores (Vim, Emacs, Sublime, etc.)
# -----------------------------------------------------------------------------
*.swp
*.swo
*.swn
*~
.netrwhist
*.sublime-workspace
*.sublime-project
.elc

# -----------------------------------------------------------------------------
# Sistemas operacionais
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# AWS CDK
# -----------------------------------------------------------------------------
cdk.out/
cdk.context.json
*.swp
.cdk.staging/

# -----------------------------------------------------------------------------
# Spring Boot - configurações sensíveis locais
# -----------------------------------------------------------------------------
application-secret.yml
application-secret.properties
application-local.yml
application-local.properties

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# Diversos
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
.history
.ionide

# Arquivos de upload locais (mockup, screenshots temporários)
uploads/
tmp/
temp/

# Notas pessoais (use docs/ para documentação versionada)
NOTES.md
TODO.md
SCRATCH.md